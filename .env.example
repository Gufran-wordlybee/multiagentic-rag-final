# Copy this file to .env and fill in your own keys.
# Never commit the real .env file — it's already in .gitignore.

# Groq (LLM inference for routing, planning, query generation, response, grading)
GROQ_API_KEY="your_groq_api_key_here"

# Cohere (contextual re-ranking of retrieved chunks)
# NOTE: langchain_cohere's CohereRerank specifically reads COHERE_API_KEY
# (not CO_API_KEY, which is what the Cohere SDK itself uses elsewhere).
COHERE_API_KEY="your_cohere_api_key_here"
